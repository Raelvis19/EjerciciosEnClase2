<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="PersonajesController"
            stylesheets="@style.css">

    <children>

        <Label layoutX="230" layoutY="30" text="Personajes Registrados">
            <font>
                <Font size="22"/>
            </font>
        </Label>

        <TableView fx:id="tablaPersonajes"
                   layoutX="40"
                   layoutY="80"
                   prefHeight="250"
                   prefWidth="620">

            <columns>

                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="100"/>
                <TableColumn fx:id="colRaza" text="Raza" prefWidth="100"/>
                <TableColumn fx:id="colPoder" text="Nivel Poder" prefWidth="100"/>
                <TableColumn fx:id="colPlaneta" text="Planeta" prefWidth="120"/>
                <TableColumn fx:id="colTecnica" text="Técnica" prefWidth="120"/>
                <TableColumn fx:id="colEdad" text="Edad" prefWidth="80"/>

            </columns>

        </TableView>

        

    </children>

</AnchorPane>